{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".medusa/server"
  },
  "include": ["medusa-config.ts", "src/**/*.ts"],
  "exclude": ["node_modules", ".medusa"]
}
